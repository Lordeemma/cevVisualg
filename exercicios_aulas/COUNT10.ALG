algoritmo "count10"
var

   counter: inteiro
   
inicio

      counter <- 0

      enquanto (counter <= 10) faca
               escreva(counter, ", ")
               counter <- counter + 1
               
               se (counter = 10) entao
                  escreva(counter, " ")
                  fimalgoritmo
               fimse
      fimenquanto
      
fimalgoritmo