algoritmo "count10to0"
var

   counter: inteiro

inicio

      counter <- 10
      
      enquanto (counter >= 0) faca
               escreva(counter, ", ")
               counter <- counter - 1
               
               se (counter = 0) entao
                  escreva(counter)
                  fimalgoritmo
               fimse
      fimenquanto

fimalgoritmo