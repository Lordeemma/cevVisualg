algoritmo "exercicioaula6"
var
   a, b, c: real
inicio
      escreva("Valor do emprķstimo: ")
      leia(a)
      escreva("N·mero de parcelas: ")
      leia(b)
      c <- ((a * 0.2 + a)/b)
      escreval("SŃo ", b, " parcelas de R$", c)
      escreval("Valor total: ", (a * 0.2 + a))
      
fimalgoritmo