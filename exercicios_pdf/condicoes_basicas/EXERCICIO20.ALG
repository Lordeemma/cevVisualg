algoritmo "exercicio20"
var
   valor: real
inicio
      escreval("PAR OU ═MPAR?")
      escreval(" ")
      escreval("Digite um n·mero: ")
      leia(valor)
      escreval(" ")
      
      se (valor mod 2 = 0) entao
         escreval("O n·mero ", valor, " ķ par.")
      senao
           escreval("O n·mero ", valor, " ķ Ēmpar.")
      fimse

fimalgoritmo