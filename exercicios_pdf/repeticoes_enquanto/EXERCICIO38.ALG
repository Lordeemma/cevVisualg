algoritmo "exercicio38"
var
   c: inteiro
inicio
      c <- 6
      escreva(c)
      enquanto (c <= 10) faca
               c <- c + 1
               escreva(C)
               
               se (c = 11) entao
                  escreva(" Acabou!")
               fimse
      fimenquanto
fimalgoritmo