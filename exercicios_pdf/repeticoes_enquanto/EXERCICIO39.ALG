algoritmo "exercicio39"
var
   c: inteiro
inicio
      c <- 10
      escreva(c)
      enquanto (c > 3) faca
               c <- c - 1
               escreva(C)
               
               se (c = 3) entao
                  escreva(" Acabou!")
               fimse
      fimenquanto
fimalgoritmo