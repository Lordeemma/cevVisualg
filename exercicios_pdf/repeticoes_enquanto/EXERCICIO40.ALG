algoritmo "exercicio40"
var
   c: inteiro
inicio
      c <- 0
      escreva(c)
      enquanto (c < 18) faca
               c <- c + 3
               escreva(C)
               
               se (c = 18) entao
                  escreva(" Acabou!")
               fimse
      fimenquanto
fimalgoritmo