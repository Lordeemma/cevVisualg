algoritmo "exercicio41"
var
   c: inteiro
inicio
      c <- 100
      escreva(c)
      enquanto (c > 0) faca
               c <- c - 5
               escreva(C)
               
               se (c = 0) entao
                  escreva(" Acabou!")
               fimse
      fimenquanto
fimalgoritmo