algoritmo "exercicio42"
var
   c, r: inteiro
inicio
      c <- 0
      escreval("Insira um número inteiro e positivo: ")
      leia(r)
      escreva(c)
      enquanto (c < r) faca
               c <- c + 1
               escreva(C)
               
               se (c = r) entao
                  escreva(" Acabou!")
               fimse
      fimenquanto
fimalgoritmo