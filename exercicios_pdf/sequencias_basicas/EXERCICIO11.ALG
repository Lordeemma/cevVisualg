algoritmo "exercicio11"
var
   a, b, c, d: real
inicio
      escreval("Descubra o valor de delta")
      escreval(" ")
      escreval("Digite o valor de A: ")
      leia(a)
      escreva("Digite o valor de B: ")
      leia(b)
      escreva("Digite o valor de C: ")
      leia(c)
      d <- exp(b, 2)-4*a*c
      escreva("Delta: ", d)
fimalgoritmo