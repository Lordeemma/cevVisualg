algoritmo "exercicio8"
var
   a, b, c: real
inicio
     escreva("Digite um número em metros: ")
     leia(a)
     b <- a / 1000
     c <- a * 100

     escreval("Tabela de conversăo de metros para quilômetros e centímetros | ", a, "m")
     escreval(" ")
     escreval(b, "km")
     escreval(c, "cm")
fimalgoritmo